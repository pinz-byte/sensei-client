# sensei_client — station environment reference
#
# Copy to .env, fill in values, then:  set -a; source .env; set +a
# .env is gitignored (see .gitignore). .env.example is the committed
# template.

# Which station this process represents in the lattice.
# Valid values: M1, M2, M3
SENSEI_STATION=M2

# Reachable URL of M3's SENSEI service. M3 itself uses localhost.
SENSEI_API_URL=http://192.168.1.237:8000

# Absolute path to the adapter JSON this station registers with SENSEI.
# Bootstrap defaults this to the HERALD spec; production ventures
# override to their own adapter.
SENSEI_ADAPTER_SPEC=/absolute/path/to/adapter.v1.json

# Python path — usually the sensei-client repo root.
PYTHONPATH=/absolute/path/to/sensei-client

# Anthropic API key for the Advisor model. Required by any venture that
# may escalate (smoke test tolerates its absence via fail-safe). Do NOT
# commit this file once filled in. chmod 600 after creation.
ANTHROPIC_API_KEY=sk-ant-...
